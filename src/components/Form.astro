<script>
    import { isInputError, actions } from 'astro:actions'
    import { getCountryCode } from '@/lib/countryCode'

    const form = document.getElementById('contact-form') as HTMLFormElement
    const submitButton = form.querySelector(
        "button[type='submit']"
    ) as HTMLButtonElement
    const responseBox = document.getElementById('response') as HTMLDivElement
    const errorBox = document.getElementById('error') as HTMLDivElement

    console.log(new URLSearchParams(window.location.search).get('ref') || 'web')

    form.addEventListener('submit', async (e) => {
        e.preventDefault()
        submitButton.disabled = true
        submitButton.textContent = 'Enviando...'
        try {
            const code = (
                document.getElementById('phone-code') as HTMLSelectElement
            ).value
            const phoneInput = (
                document.getElementById('phone') as HTMLInputElement
            ).value
            const fullPhone = code + ' ' + phoneInput
            const { name, email, travel_time } = Object.fromEntries(
                new FormData(form).entries()
            )
            const { data, error } = await actions.sendForm({
                name: name as string,
                phone: fullPhone,
                email: email as string,
                travel_time: travel_time as
                    '0-3' | '3-6' | '6-12' | '12-18' | '0',
                referralCode:
                    new URLSearchParams(window.location.search).get('ref') ||
                    'web'
            })

            if (data === 'success') {
                errorBox.innerHTML = ''
                form.phone.value = ''
                form.email.value = ''
                form.travel_time.value = '0-3'
                responseBox.textContent =
                    '✅ Tu solicitud ha sido enviada exitosamente. Nos pondremos en contacto contigo pronto.'
            }
            if (error) {
                console.error('Error al enviar el formulario:', error)
                responseBox.textContent = `❌ Ocurrió un error al enviar el formulario. Por favor, Intenta de nuevo.`
            }
            if (error && isInputError(error)) {
                responseBox.textContent = `❌ Ocurrió un error al enviar el formulario. Por favor, Revisa Los errores.`

                errorBox.innerHTML = ''
                Object.entries(error.fields).forEach(([key, value]) => {
                    const errorItem = document.createElement('p')
                    errorItem.textContent = Array.isArray(value)
                        ? value.join(', ')
                        : (value ?? '')
                    errorBox.appendChild(errorItem)
                })
            }
        } catch (error: Error | any) {
            responseBox.textContent =
                '❌ Ocurrió un error al enviar el formulario. Por favor, intenta de nuevo.'
        } finally {
            submitButton.disabled = false
            submitButton.textContent = 'Enviar'
        }
    })

