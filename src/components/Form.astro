    const dropdownBtn = document.getElementById('country-code-btn') as HTMLButtonElement
    const dropdownMenu = document.getElementById('country-dropdown-menu') as HTMLDivElement
    const searchInput = document.getElementById('country-search') as HTMLInputElement
    const countryList = document.getElementById('country-list') as HTMLUListElement
    const selectedFlag = document.getElementById('selected-flag') as HTMLSpanElement
    const selectedCode = document.getElementById('selected-code') as HTMLSpanElement
    const phoneCodeInput = document.getElementById('phone-code') as HTMLInputElement

    const seen = new Set<string>()
    const uniqueCountries = countryCodes.filter((cc) => {
        if (seen.has(cc.country)) return false
        seen.add(cc.country)
        return true
    })

    function renderCountries(filter = '') {
        countryList.innerHTML = ''
        const lowerFilter = filter.toLowerCase()
        const filtered = uniqueCountries.filter(
            (cc) =>
                cc.name.toLowerCase().includes(lowerFilter) ||
                cc.code.includes(filter) ||
                cc.country.toLowerCase().includes(lowerFilter)
        )

        if (filtered.length === 0) {
            const li = document.createElement('li')
            li.className = 'px-4 py-3 text-sm text-on-surface-variant'
            li.textContent = 'No se encontraron resultados'
            countryList.appendChild(li)
            return
        }

        for (const cc of filtered) {
            const li = document.createElement('li')
            li.className =
                'px-4 py-3 cursor-pointer hover:bg-primary/10 transition-colors flex items-center gap-3'
            li.innerHTML = `
                <span class='text-lg'>${cc.flag}</span>
                <span class='flex-1 font-body-md text-sm'>${cc.name}</span>
                <span class='text-on-surface-variant text-sm'>${cc.code}</span>
            `
            li.addEventListener('click', () => {
                selectedFlag.textContent = cc.flag
                selectedCode.textContent = cc.code
                phoneCodeInput.value = cc.code
                dropdownMenu.classList.add('hidden')
                searchInput.value = ''
            })
            countryList.appendChild(li)
        }
    }

    dropdownBtn.addEventListener('click', (e) => {
        e.stopPropagation()
        const isHidden = dropdownMenu.classList.contains('hidden')
        dropdownMenu.classList.toggle('hidden')
        if (isHidden) {
            renderCountries()
            setTimeout(() => searchInput.focus(), 50)
        }
    })

    searchInput.addEventListener('input', (e) => {
        renderCountries((e.target as HTMLInputElement).value)
    })

    document.addEventListener('click', (e) => {
        const dropdown = document.getElementById('country-code-dropdown')
        if (dropdown && !dropdown.contains(e.target as Node)) {
            dropdownMenu.classList.add('hidden')
            searchInput.value = ''
        }
    })

    renderCountries()

    ;(async () => {
        try {
            const { data } = await actions.getCountry()
            if (data?.countryCode) {
                const match = countryCodes.find(
                    (c) => c.country === data.countryCode
                )
                if (match) {
                    selectedFlag.textContent = match.flag
                    selectedCode.textContent = match.code
                    phoneCodeInput.value = match.code
                }
            }
        } catch {
            // fallback: leave default selected
        }
    })()
</script>
