<script>
    import { isInputError, actions } from 'astro:actions'

    const form = document.getElementById('contact-form') as HTMLFormElement
    const submitButton = form.querySelector(
        "button[type='submit']"
    ) as HTMLButtonElement
    const btnText = submitButton.querySelector('.btn-text') as HTMLSpanElement
    const btnIcon = submitButton.querySelector('.btn-icon') as HTMLSpanElement
    const feedbackContainer = document.getElementById(
        'feedback-container'
    ) as HTMLDivElement
    const feedbackSuccess = document.getElementById(
        'feedback-success'
    ) as HTMLDivElement
    const feedbackError = document.getElementById(
        'feedback-error'
    ) as HTMLDivElement
    const feedbackNetworkError = document.getElementById(
        'feedback-network-error'
    ) as HTMLDivElement
    const errorDetails = document.getElementById(
        'error-details'
    ) as HTMLDivElement
    const resetFormBtn = document.getElementById(
        'reset-form-btn'
    ) as HTMLButtonElement

    console.log(new URLSearchParams(window.location.search).get('ref') || 'web')

    function setLoading(loading: boolean) {
        if (loading) {
            submitButton.disabled = true
            btnText.textContent = 'Enviando...'
            btnIcon.innerHTML =
                '<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" stroke-dasharray="60" stroke-dashoffset="20"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="1s" repeatCount="indefinite"/></circle>'
            submitButton.classList.add('opacity-75', 'cursor-not-allowed')
        } else {
            submitButton.disabled = false
            btnText.textContent = 'Enviar'
            btnIcon.textContent = 'send'
            submitButton.classList.remove('opacity-75', 'cursor-not-allowed')
        }
    }

    function showFeedback(
        type: 'success' | 'error' | 'network-error',
        errors?: Record<string, string>
    ) {
        feedbackContainer.classList.remove('hidden')
        feedbackSuccess.classList.add('hidden')
        feedbackError.classList.add('hidden')
        feedbackNetworkError.classList.add('hidden')

        if (type === 'success') {
            feedbackSuccess.classList.remove('hidden')
            form.classList.add('hidden')
        } else if (type === 'error') {
            feedbackError.classList.remove('hidden')
            errorDetails.innerHTML = ''
            if (errors) {
                Object.entries(errors).forEach(([field, message]) => {
                    const item = document.createElement('div')
                    item.className =
                        'flex items-center gap-2 text-sm text-red-700'
                    item.innerHTML = `<span class="material-symbols-outlined text-sm">warning</span><span>${message}</span>`
                    errorDetails.appendChild(item)
                })
            }
        } else {
            feedbackNetworkError.classList.remove('hidden')
        }

        feedbackContainer.scrollIntoView({
            behavior: 'smooth',
            block: 'nearest'
        })
    }

    function resetForm() {
        form.reset()
        form.classList.remove('hidden')
        feedbackContainer.classList.add('hidden')
        feedbackSuccess.classList.add('hidden')
        feedbackError.classList.add('hidden')
        feedbackNetworkError.classList.add('hidden')
        errorDetails.innerHTML = ''
        ;(form.elements.namedItem('name') as HTMLInputElement)?.focus()
    }

    resetFormBtn.addEventListener('click', resetForm)

    form.addEventListener('submit', async (e) => {
        e.preventDefault()
        setLoading(true)

        try {
            const code = (
                document.getElementById('phone-code') as HTMLSelectElement
            ).value
            const phoneInput = (
                document.getElementById('phone') as HTMLInputElement
            ).value
            const fullPhone = code + ' ' + phoneInput
            const { name, email, travel_time } = Object.fromEntries(
                new FormData(form).entries()
            )
            const { data, error } = await actions.sendForm({
                name: name as string,
                phone: fullPhone,
                email: email as string,
                travel_time: travel_time as
                    '0-3' | '3-6' | '6-12' | '12-18' | '0',
                referralCode:
                    new URLSearchParams(window.location.search).get('ref') ||
                    'web'
            })

            if (data === 'success') {
                showFeedback('success')
            } else if (error) {
                console.error('Error al enviar el formulario:', error)
                if (isInputError(error)) {
                    const fieldErrors: Record<string, string> = {}
                    Object.entries(error.fields).forEach(([key, value]) => {
                        fieldErrors[key] = Array.isArray(value)
                            ? value.join(', ')
                            : (value ?? '')
                    })
                    showFeedback('error', fieldErrors)
                } else {
                    showFeedback('error')
                }
            }
        } catch (err: Error | any) {
            console.error('Error de red:', err)
            showFeedback('network-error')
        } finally {
            setLoading(false)
        }
    })

