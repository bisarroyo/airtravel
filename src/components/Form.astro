    ]

    const codeSelect = document.getElementById(
        'phone-code'
    ) as HTMLSelectElement

    const seen = new Set<string>()
    for (const cc of countryCodes) {
        if (seen.has(cc.country)) continue
        seen.add(cc.country)
        const opt = document.createElement('option')
        opt.value = cc.code
        opt.textContent = cc.label
        codeSelect.appendChild(opt)
    }

    ;(async () => {
        try {
            const detected = await getCountryCode()
            if (detected) {
                const match = countryCodes.find((c) => c.country === detected)
                if (match) {
                    codeSelect.value = match.code
                }
            }
        } catch {
            // fallback: leave default selected
        }
    })()
</script>
