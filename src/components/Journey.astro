---
import { Image } from 'astro:assets'
import programImage from '../assets/images/program.webp'
---

<section class='py-xl bg-surface relative overflow-hidden'>
    <div
        class='blob w-[500px] h-[500px] bg-primary-container/10 -left-64 -top-64'>
    </div>
    <div class='max-w-container-max mx-auto px-gutter'>
        <div
            class='flex flex-col lg:flex-row justify-between items-end mb-16 gap-8'>
            <div
                class='max-w-2xl animate-on-scroll animate-fadeInLeft'
                style='animation-delay: 0.2s'>
                <h2
                    class='font-headline-lg text-4xl md:text-6xl text-secondary mb-6 leading-tight'>
                    ¿Por qué elegir la <br /><span class='text-primary'
                        >Isla Esmeralda?</span
                    >
                </h2>
                <p class='font-body-lg text-body-lg text-on-surface-variant'>
                    Irlanda no es solo un destino, es el hub tecnológico de
                    Europa y el lugar ideal para perfeccionar tu inglés mientras
                    ganas experiencia laboral real en un entorno cosmopolita.
                </p>
            </div>
            <div
                class='flex gap-4 animate-on-scroll animate-fadeInRight'
                style='animation-delay: 0.4s'>
                <a
                    class='bg-secondary text-white px-8 py-3 rounded-full font-button text-sm hover:bg-on-secondary-fixed-variant transition-all'
                    href='/programa'>Saber más</a
                >
                <a
                    class='border border-outline px-8 py-3 rounded-full font-button text-sm hover:bg-surface-container transition-all'
                    href='/programa#guia'>Ver guía</a
                >
            </div>
        </div>
        <div
            class='grid grid-cols-1 md:grid-cols-12 gap-gutter hover-group:cursor-pointer'>
            <a
                href='/programa'
                class='md:col-span-8 group relative rounded-[2.5rem] overflow-hidden aspect-[16/9] shadow-2xl block animate-on-scroll animate-fadeInLeft'
                style='animation-delay: 0.3s'>
                <Image src={programImage} alt='Dublin image' />
                <div
                    class='absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent'>
                </div>
                <div class='absolute top-6 right-6'>
                    <span
                        class='bg-tertiary/90 backdrop-blur-md text-white px-4 py-1.5 rounded-full text-xs font-bold uppercase'
                        >Ver programa completo</span
                    >
                </div>
                <div class='absolute bottom-8 left-8 text-white max-w-md'>
                    <h3 class='text-3xl font-headline-md mb-4'>
                        Experiencia Dublín: Work &amp; Study
                    </h3>
                </div>
            </a>
            <div
                class='md:col-span-4 group relative rounded-[2.5rem] overflow-hidden aspect-square md:aspect-auto shadow-2xl animate-on-scroll animate-fadeInRight'
                style='animation-delay: 0.5s'>
                <img
                    alt='Irish Pub Culture'
                    class='w-full h-full object-cover transition-transform duration-700 group-hover:scale-110'
                    src='https://lh3.googleusercontent.com/aida-public/AB6AXuCwVvTbYgKUscMpGG13Oue9bKQzDMzUdDT1eNN58ZGOlvb3bLdGubtTk06pUXeHKZQfoqUfckz_01v9au9hsM-0tzorrmWD5Un-_uSNabrz1BLX-h15-dQ6b1m73I8CQ2zu0DsPsB_ax-MwdJ7b-GsylfX0yPLbo4htT_qBEzFCAWDW6Z4vJPRyvIMj4iGMCWquiOiKtubqw18Ls9kUtbDPh0620bCKeDWpOD6FZ7v58DsOw-VMo6BO'
                />
                <div
                    class='absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-colors'>
                </div>
                <div class='absolute inset-0 flex items-center justify-center'>
                    <div
                        class='w-16 h-16 glass-card rounded-full flex items-center justify-center text-white group-hover:scale-110 transition-transform'>
                        <span
                            class='material-symbols-outlined text-4xl'
                            style="font-variation-settings: 'FILL' 1;"
                            >play_arrow</span
                        >
                    </div>
                </div>
                <div class='absolute bottom-8 left-8 text-white'>
                    <p
                        class='text-xs font-bold uppercase tracking-widest opacity-80'>
                        Cultura Local
                    </p>
                    <h3 class='text-xl font-headline-md'>
                        Vida Nocturna &amp; Networking
                    </h3>
                </div>
            </div>
        </div>
    </div>
</section>
