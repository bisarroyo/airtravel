---
interface Props {
    title: string
    subtitle?: string
    image?: string
}

const { title, subtitle } = Astro.props
---

<section class='relative min-h-[50vh] flex items-center justify-center overflow-hidden bg-secondary'>
    <div class='absolute inset-0 bg-gradient-to-br from-secondary via-primary to-secondary/90'></div>
    <div class='absolute inset-0 opacity-10'>
        <div class='absolute top-1/4 left-1/4 w-96 h-96 bg-primary rounded-full blur-3xl'></div>
        <div class='absolute bottom-1/4 right-1/4 w-64 h-64 bg-tertiary rounded-full blur-3xl'></div>
    </div>
    <div class='relative z-10 max-w-container-max mx-auto px-gutter text-center'>
        <h1 class='font-headline-lg text-4xl md:text-6xl font-black text-white mb-4 text-shadow'>
            {title}
        </h1>
        {subtitle && (
            <p class='text-body-lg text-white/80 max-w-2xl mx-auto'>
                {subtitle}
            </p>
        )}
        <div class='mt-8 w-24 h-1 bg-tertiary mx-auto rounded-full'></div>
    </div>
</section>
