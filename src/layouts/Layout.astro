---
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import Form from '../components/Form.astro'
---

<!doctype html>
<html class='light' lang='es'>
    <head>
        <meta charset='utf-8' />
        <meta content='width=device-width, initial-scale=1.0' name='viewport' />
        <title>Air Travel | Vive y Trabaja en Irlanda</title>
        <script
            src='https://cdn.tailwindcss.com?plugins=forms,container-queries'
            is:inline></script>
        <link
            href='https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap'
            rel='stylesheet'
        />
        <script is:inline>
            tailwind.config = {
                darkMode: 'class',
                theme: {
                    extend: {
                        colors: {
                            primary: '#30818B',
                            'primary-container': '#30818B',
                            'on-primary': '#2D3436',
                            'on-primary-container': '#2D3436',
                            secondary: '#184E63',
                            'on-secondary': '#2D3436',
                            'on-secondary-fixed-variant': '#184E63',
                            tertiary: '#C76A3A',
                            'on-tertiary': '#2D3436',
                            cream: '#F3E8D4',
                            'on-cream': '#2D3436',
                            surface: '#FAFAF8',
                            'surface-container': '#FAFAF8',
                            'surface-container-low': '#FAFAF8',
                            'surface-variant': '#FAFAF8',
                            background: '#FAFAF8',
                            'on-surface': '#2D3436',
                            'on-surface-variant': '#2D3436',
                            'on-background': '#2D3436',
                            outline: '#2D3436',
                            'outline-variant': '#FAFAF8'
                        },
                        borderRadius: {
                            DEFAULT: '0.25rem',
                            lg: '0.5rem',
                            xl: '0.75rem',
                            full: '9999px',
                            '2xl': '1rem',
                            '3xl': '1.5rem'
                        },
                        spacing: {
                            md: '24px',
                            base: '8px',
                            lg: '48px',
                            gutter: '24px',
                            xl: '80px',
                            sm: '12px',
                            'container-max': '1280px',
                            xs: '4px'
                        },
                        fontFamily: {
                            'headline-md': ['Poppins'],
                            'label-md': ['Poppins'],
                            'display-lg': ['Poppins'],
                            button: ['Poppins'],
                            'body-md': ['Poppins'],
                            'body-lg': ['Poppins'],
                            'headline-lg-mobile': ['Poppins'],
                            'headline-lg': ['Poppins']
                        },
                        fontSize: {
                            'headline-md': [
                                '24px',
                                { lineHeight: '32px', fontWeight: '700' }
                            ],
                            'label-md': [
                                '14px',
                                { lineHeight: '20px', fontWeight: '600' }
                            ],
                            'display-lg': [
                                '56px',
                                {
                                    lineHeight: '64px',
                                    letterSpacing: '-0.02em',
                                    fontWeight: '800'
                                }
                            ],
                            button: [
                                '16px',
                                { lineHeight: '20px', fontWeight: '700' }
                            ],
                            'body-md': [
                                '16px',
                                { lineHeight: '24px', fontWeight: '400' }
                            ],
                            'body-lg': [
                                '18px',
                                { lineHeight: '28px', fontWeight: '400' }
                            ],
                            'headline-lg-mobile': [
                                '32px',
                                { lineHeight: '40px', fontWeight: '700' }
                            ],
                            'headline-lg': [
                                '40px',
                                {
                                    lineHeight: '48px',
                                    letterSpacing: '-0.01em',
                                    fontWeight: '700'
                                }
                            ]
                        }
                    }
                }
            }
        </script>
        <style is:global>
            .material-symbols-outlined {
                font-variation-settings:
                    'FILL' 0,
                    'wght' 400,
                    'GRAD' 0,
                    'opsz' 24;
            }
            .glass-card {
                background: rgba(255, 255, 255, 0.1);
                backdrop-filter: blur(16px);
                -webkit-backdrop-filter: blur(16px);
                border: 1px solid rgba(255, 255, 255, 0.2);
            }
            .glass-light {
                background: rgba(255, 255, 255, 0.7);
                backdrop-filter: blur(8px);
                -webkit-backdrop-filter: blur(8px);
            }
            .hero-gradient {
                background: linear-gradient(
                    to bottom,
                    rgba(0, 0, 0, 0.1) 0%,
                    rgba(0, 0, 0, 0.6) 100%
                );
            }
            .text-shadow {
                text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
            }
            .blob {
                position: absolute;
                filter: blur(80px);
                z-index: -1;
                border-radius: 50%;
                opacity: 0.2;
            }
            body {
                font-family: 'Poppins', sans-serif;
            }
            * {
                scroll-behavior: smooth;
            }

            @keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(40px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
            @keyframes fadeInLeft {
                from {
                    opacity: 0;
                    transform: translateX(-40px);
                }
                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }
            @keyframes fadeInRight {
                from {
                    opacity: 0;
                    transform: translateX(40px);
                }
                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }
            @keyframes scaleIn {
                from {
                    opacity: 0;
                    transform: scale(0.9);
                }
                to {
                    opacity: 1;
                    transform: scale(1);
                }
            }
            @keyframes slideDown {
                from {
                    opacity: 0;
                    transform: translateY(-20px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
            @keyframes kenburns {
                from {
                    transform: scale(1);
                }
                to {
                    transform: scale(1.1);
                }
            }

            .animate-on-scroll {
                opacity: 0;
            }
            .animate-on-scroll.animate-fadeInUp {
                animation: fadeInUp 0.8s ease-out forwards;
            }
            .animate-on-scroll.animate-fadeInLeft {
                animation: fadeInLeft 0.8s ease-out forwards;
            }
            .animate-on-scroll.animate-fadeInRight {
                animation: fadeInRight 0.8s ease-out forwards;
            }
            .animate-on-scroll.animate-scaleIn {
                animation: scaleIn 0.8s ease-out forwards;
            }
            .animate-on-scroll.animate-slideDown {
                animation: slideDown 0.6s ease-out forwards;
            }
        </style>
    </head>
    <body
        class='bg-background text-on-background font-body-md overflow-x-hidden'>
        <Nav />
        <slot />
        <Form />
        <Footer />
    </body>
</html>
<script>
    window.addEventListener('scroll', () => {
        const nav = document.getElementById('main-nav')
        if (!nav) return
        const container = nav.firstElementChild
        if (!container) return

        const isScrolled = window.scrollY > 50

        if (isScrolled) {
            nav.classList.add('py-2')
            container.classList.add(
                'bg-white/90',
                'backdrop-blur-2xl',
                'border-black/5',
                'shadow-2xl'
            )
            container.classList.remove('bg-white/10', 'border-white/20')
            container.querySelectorAll('.nav-link').forEach((a) => {
                a.classList.remove('text-white')
                a.classList.add('text-secondary')
            })
            const brand = document.getElementById('nav-brand')
            if (brand) {
                brand.classList.remove('text-white')
                brand.classList.add('text-secondary')
            }
        } else {
            nav.classList.remove('py-2')
            container.classList.remove(
                'bg-white/90',
                'backdrop-blur-2xl',
                'border-black/5',
                'shadow-2xl'
            )
            container.classList.add('bg-white/10', 'border-white/20')
            container.querySelectorAll('.nav-link').forEach((a) => {
                a.classList.add('text-white')
                a.classList.remove('text-secondary')
            })
            const brand = document.getElementById('nav-brand')
            if (brand) {
                brand.classList.add('text-white')
                brand.classList.remove('text-secondary')
            }
        }
    })

    document.addEventListener('DOMContentLoaded', () => {
        const heroSection = document.querySelector('section:first-of-type')
        const isLegalPage = heroSection && heroSection.querySelector('h1') && !heroSection.querySelector('.blob') && !heroSection.querySelector('img')

        if (isLegalPage) return

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('animate-on-scroll', 'animate-fadeInUp')
                        observer.unobserve(entry.target)
                    }
                })
            },
            { threshold: 0.1 }
        )

        document
            .querySelectorAll('section > div:first-child, .group, .bg-white, .bg-white\\/10')
            .forEach((el) => {
                observer.observe(el)
            })
    })
</script>
