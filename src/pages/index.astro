---
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Journey from '../components/Journey.astro';
import Benefits from '../components/Benefits.astro';
import Testimonial from '../components/Testimonial.astro';
import Form from '../components/Form.astro';
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<Nav />
	<Hero />
	<Journey />
	<Benefits />
	<Testimonial />
	<Form />
	<Footer />
</Layout>

<script>
	window.addEventListener('scroll', () => {
		const nav = document.getElementById('main-nav');
		if (!nav) return;
		const container = nav.firstElementChild;
		if (!container) return;
		if (window.scrollY > 50) {
			nav.classList.add('py-2');
			container.classList.add('bg-white/80', 'backdrop-blur-2xl', 'border-black/5', 'shadow-2xl');
			container.classList.remove('bg-white/10', 'border-white/20');
			container.querySelectorAll('a').forEach(a => {
				a.classList.remove('text-white');
				a.classList.add('text-secondary');
			});
			const brand = container.querySelector('.font-black');
			if (brand) {
				brand.classList.remove('text-white');
				brand.classList.add('text-secondary');
			}
		} else {
			nav.classList.remove('py-2');
			container.classList.remove('bg-white/80', 'backdrop-blur-2xl', 'border-black/5', 'shadow-2xl');
			container.classList.add('bg-white/10', 'border-white/20');
			container.querySelectorAll('a').forEach(a => {
				a.classList.add('text-white');
				a.classList.remove('text-secondary');
			});
			const brand = container.querySelector('.font-black');
			if (brand) {
				brand.classList.add('text-white');
				brand.classList.remove('text-secondary');
			}
		}
	});

	document.addEventListener('DOMContentLoaded', () => {
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.classList.add('opacity-100', 'translate-y-0');
					entry.target.classList.remove('opacity-0', 'translate-y-10');
				}
			});
		}, { threshold: 0.1 });

		document.querySelectorAll('section > div:first-child, .group').forEach(el => {
			el.classList.add('transition-all', 'duration-1000', 'opacity-0', 'translate-y-10');
			observer.observe(el);
		});
	});
</script>
